# Copy to .env and edit. .env is gitignored — never commit real keys.
# Every value here mirrors a field in config.py (pydantic-settings). Anything you
# leave unset falls back to the laptop-friendly defaults in config.py.

# ---------- corpus ----------
# arXiv API query. Default pulls recent ML papers.
ARXIV_QUERY=cat:cs.LG OR cat:cs.CL OR cat:cs.AI
NUM_PAPERS=50

# ---------- chunking (ablation axis: 256 / 512 / 1024) ----------
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ---------- embeddings ----------
EMBEDDING_MODEL=BAAI/bge-m3
# cpu | cuda  (laptops use cpu)
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=4

# ---------- retrieval (ablation knobs) ----------
# dense | hybrid
RETRIEVAL_STRATEGY=dense
TOP_K=5
USE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ---------- LLM (local-first; API options are opt-in) ----------
# ollama | groq | gemini
LLM_PROVIDER=ollama

# -- Ollama (no key; run `ollama pull llama3.1` first) --
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# -- Groq (free tier; set a key to use) --
# GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# -- Gemini (free tier; set a key to use) --
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---------- agentic layer (phase 4 toggle) ----------
USE_AGENTIC=false
